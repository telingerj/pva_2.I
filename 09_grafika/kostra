import pygame

pygame.init()
clock = pygame.time.Clock()

screen = pygame.display.set_mode((400, 300))

running = True
while running:
    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            running = False

    screen.fill((0, 0, 0))
    clock.tick(60)
    pygame.display.flip()

pygame.quit()
